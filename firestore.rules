rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // For now, allowing all access to facilitate development as requested by the user,
    // but in a real app, we would use isAuthenticated() and ownership checks.
    match /employees/{employeeId} {
      allow read, write: if true;
    }
    
    match /conversations/{conversationId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
