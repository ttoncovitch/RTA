rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Since authentication is handled locally in the client for demonstration purposes,
    // we allow read/write access. In a production app, real Firebase Auth should be used.
    match /employees/{employeeId} {
      allow read, write: if true;
    }
    
    match /conversations/{conversationId} {
      allow read, write: if true;
    }
  }
}
